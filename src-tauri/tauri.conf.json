{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "LetsStream",
  "version": "0.0.1",
  "identifier": "com.chintan992.letsstream2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Let's Stream",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        {
          "scheme": ["letsstream2"],
          "appLink": false
        }
      ],
      "desktop": {
        "schemes": ["letsstream2"]
      }
    }
  }
}
